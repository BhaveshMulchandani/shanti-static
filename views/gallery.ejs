      <button data-filter="patients">Patients</button>
      <button data-filter="technology">Technology</button>
    </div>

    <div class="gallery-grid">

      <div class="gallery-item clinic">
        <img src="/images/gallery/clinic1.jpg" alt="">
      </div>

      <div class="gallery-item clinic">
        <img src="/images/gallery/clinic2.jpg" alt="">
      </div>

      <div class="gallery-item dental">
        <img src="/images/gallery/dental1.jpg" alt="">
      </div>

      <div class="gallery-item dental">
        <img src="/images/gallery/dental2.jpg" alt="">
      </div>

      <div class="gallery-item patients">
        <img src="/images/gallery/patient1.jpg" alt="">
      </div>

      <div class="gallery-item patients">
        <img src="/images/gallery/patient2.jpg" alt="">
      </div>

      <div class="gallery-item technology">
        <img src="/images/gallery/tech1.jpg" alt="">
      </div>

      <div class="gallery-item technology">
        <img src="/images/gallery/tech2.jpg" alt="">
      </div>

      <div class="gallery-item clinic">
        <img src="/images/gallery/clinic3.jpg" alt="">
      </div>

      <div class="gallery-item dental">
        <img src="/images/gallery/dental3.jpg" alt="">
      </div>

      <div class="gallery-item patients">
        <img src="/images/gallery/patient3.jpg" alt="">
      </div>

      <div class="gallery-item technology">
        <img src="/images/gallery/tech3.jpg" alt="">
      </div>

    </div>

  </div>
</section>

