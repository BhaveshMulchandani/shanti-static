<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About - Shanti Dental Clinic</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body>

    <div class="switch-banner dental">
        Looking for skin, hair or aesthetic care?
        <a href="/aesthetic">✨ Switch to Shanti Aesthetic Clinic →</a>
    </div>

    <header class="site-nav dental">
        <div class="nav-inner">
            <a href="/dental" class="brand dental">
                <img src="/images/Transparent Logo.png" alt="Shanti Dental Clinic" class="logo">
                <span>Shanti Dental Clinic</span>
            </a>
            <nav class="nav-links">
                <a href="/dental">Home</a>
                <div class="services-dropdown-wrapper">
                    <a href="#" id="servicesBtn"> Services </a>

                    <div class="services-dropdown-menu" id="servicesMenu">

                        <% services.forEach(service=> { %>

                            <a href="/services/<%= service.slug %>">
                                <%= service.title %>
                            </a>

                            <% }) %>

                    </div>
                </div>

<div class="services-dropdown-wrapper">
    <a href="#">Conditions</a>

    <div class="services-dropdown-menu">

        <% conditions.forEach(condition => { %>

            <a href="/conditions/<%= condition.slug %>">
                <%= condition.title %>
            </a>

        <% }) %>

    </div>
</div>
                <a href="/gallery">Gallery</a>
                <a href="/about">About us</a>
                <a href="/contactus">Contact Us</a>
                <a href="/blog">Blogs</a>
                <a href="/aesthetic" class="pill-switch to-aesthetic">✨ Switch to Aesthetic</a>
                <a href="/appointment" class="btn-book dental">
                    <i data-lucide="calendar"></i>
                    Book Appointment
                </a>
            </nav>
            <button class="nav-toggle" aria-label="Menu" data-menu-toggle>
                <i data-lucide="menu"></i>
            </button>
        </div>
        <div class="mobile-menu" data-menu>
            <a href="/dental">Home</a>
            <a href="#services">Services</a>
            <a href="#gallery">Gallery</a>
            <a href="aesthetic.html" style="color: var(--aesthetic)">✨ Switch to Aesthetic</a>
            <button class="btn-book dental">Book Appointment</button>
        </div>
    </header>

    <main class="blog-detail-page">

        <!-- Breadcrumb -->
        <section class="breadcrumb-section">
            <div class="container">
                <a href="/dental">Home</a>
                <span>/</span>
                <a href="/blogs">Blogs</a>
                <span>/</span>
                <span>
                    <%= blog.title %>
                </span>
            </div>
        </section>

        <!-- Hero -->
        <section class="blog-detail-hero">

            <div class="container">

                <div class="blog-detail-image">

                    <img src="<%= blog.image %>" alt="<%= blog.title %>">

                    <span class="blog-category">

                        <%= blog.category %>

                    </span>

                </div>

                <div class="blog-detail-header">

                    <div class="blog-meta">

                        <span>

                            <i data-lucide="calendar-days"></i>

                            <%= blog.date %>

                        </span>

                        <span>

                            <i data-lucide="clock-3"></i>

                            <%= blog.readTime %>

                        </span>

                    </div>

                    <h1>

                        <%= blog.title %>

                    </h1>

                    <p class="blog-subtitle">

                        <%= blog.excerpt %>

                    </p>

                    <div class="blog-author">

                        <img src="/images/doctor.png" alt="Doctor">

                        <div>

                            <h4>

                                <%= blog.author %>

                            </h4>

                            <span>
                                Dental Surgeon
                            </span>

                        </div>

                    </div>

                </div>

            </div>

        </section>



        <!-- Content -->

        <section class="blog-content-wrapper">

            <div class="container">

                <div class="blog-layout">

                    <!-- LEFT -->

                    <article class="blog-content">

                        <div class="blog-intro">

                            <p class="drop-cap">

                                <%- blog.content %>

                            </p>

                        </div>

                    </article>



                    <!-- RIGHT -->

                    <aside class="blog-sidebar">

                        <div class="sidebar-card">

                            <h3>

                                Book Appointment

                            </h3>

                            <p>

                                Looking for expert dental treatment?

                                Schedule your consultation with our specialists.

                            </p>

                            <a href="/appointment" class="btn-book dental">

                                Book Now

                            </a>

                        </div>



                        <div class="sidebar-card">

                            <h3>

                                Our Services

                            </h3>

                            <ul>

                                <% services.forEach(service=>{ %>

                                    <li>

                                        <a href="/services/<%= service.slug %>">

                                            <%= service.title %>

                                        </a>

                                    </li>

                                    <% }) %>

                            </ul>

                        </div>



                        <div class="sidebar-card">

                            <h3>

                                Share Article

                            </h3>

                            <div class="share-icons">

                                <a href="#">

                                    <i data-lucide="facebook"></i>

                                </a>

                                <a href="#">

                                    <i data-lucide="instagram"></i>

                                </a>

                                <a href="#">

                                    <i data-lucide="linkedin"></i>

                                </a>

                                <a href="#">

                                    <i data-lucide="message-circle"></i>

                                </a>

                            </div>

                        </div>

                    </aside>

                </div>

            </div>

        </section>



        <!-- Related Blogs -->

        <section class="related-blogs">

            <div class="container">

                <div class="section-title">

                    <span>Continue Reading</span>

                    <h2>Related Blogs</h2>

                </div>

                <div class="blog-grid">

                    <% blogs.slice(0,3).forEach(item=>{ %>

                        <% if(item.slug!==blog.slug){ %>

                            <article class="blog-card">

                                <a href="/blogs/<%= item.slug %>">

                                    <div class="blog-image">

                                        <img src="<%= item.image %>">

                                        <span class="category">

                                            <%= item.category %>

                                        </span>

                                    </div>

                                </a>

                                <div class="blog-content">

                                    <h3>

                                        <a href="/blogs/<%= item.slug %>">

                                            <%= item.title %>

                                        </a>

                                    </h3>

                                    <p>

                                        <%= item.excerpt %>

                                    </p>

                                    <a href="/blogs/<%= item.slug %>" class="read-more">

                                        Read More →

                                    </a>

                                </div>

                            </article>

                            <% } %>

                                <% }) %>

                </div>

            </div>

        </section>



        <!-- Bottom CTA -->

        <section class="blog-cta">

            <div class="container">

                <h2>

                    Your Healthy Smile Starts Here

                </h2>

                <p>

                    Book your consultation with Shanti Dental Clinic today.

                </p>

                <a href="/appointment" class="btn-book dental">

                    Book Appointment

                </a>

            </div>

        </section>

    </main>

    <footer class="site-footer">
        <div class="footer-grid">
            <div>
                <h3>Shanti Clinic Group</h3>
                <p>
                    A unified destination for dental excellence and aesthetic refinement
                    — built on clinical precision, modern technology, and personal care.
                </p>
            </div>
            <div>
                <h4>Dental</h4>
                <ul class="footer-services">
                    <li>
                        <a href="aligners.html">Aligners</a>
                    </li>

                    <li>
                        <a href="braces.html">Braces</a>
                    </li>

                    <li>
                        <a href="implants.html">Dental Implants & Dentures</a>
                    </li>

                    <li>
                        <a href="pediatric.html">Paediatric (Child) & Habit Converting Dentistry</a>
                    </li>
                </ul>
                <a class="footer-link dental" href="dental.html">Visit Dental →</a>
            </div>
            <div>
                <h4>Aesthetic</h4>
                <ul>
                    <li>Skin Rejuvenation</li>
                    <li>Anti-Aging Solutions</li>
                    <li>Laser & Hair Therapies</li>
                    <li>Body Contouring</li>
                </ul>
                <a class="footer-link aesthetic" href="aesthetic.html">Visit Aesthetic →</a>
            </div>
            <div>
                <h4>Contact</h4>
                <ul>
                    <li><i data-lucide="phone"></i> +91 87329 29431</li>
                    <li><i data-lucide="mail"></i> care@shanticlinic.com</li>
                    <li>
                        <i data-lucide="map-pin"></i> 1st floor, Avadh Pride, 143, Nirant Cross Rd, opp. Metro pillar
                        no. 139, Vastral, Ahmedabad, Gujarat 382418
                    </li>
                </ul>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="footer-bottom-inner">
                <p>© 2026 Shanti Clinic Group. All rights reserved.</p>
                <p>Crafted with care · Privacy · Terms</p>
            </div>
        </div>
    </footer>

    <!-- Floating Contact Buttons -->
    <div class="floating-contact">
        <a href="https://wa.me/8732929431" target="_blank" class="contact-btn whatsapp-btn" aria-label="WhatsApp">
            <i data-lucide="message-circle"></i>
        </a>

        <a href="tel:+918732929431" class="contact-btn call-btn" aria-label="Call">
            <i data-lucide="phone"></i>
        </a>
    </div>

    <!-- Mobile Sticky Contact Bar -->
    <div class="mobile-contact-bar">
        <a href="https://wa.me/8732929431" target="_blank" class="mobile-wa">
            <i data-lucide="message-circle"></i>
            WhatsApp
        </a>

        <a href="tel:+91 8732929431" class="mobile-call">
            <i data-lucide="phone"></i>
            Call Now
        </a>
    </div>

    <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
    <script src="/js/main.js"></script>
</body>

</html>