    <main class="about-page">

  <!-- HERO -->

  <section class="about-hero">

    <div class="container about-hero-grid">

      <div>

        <span class="about-tag">
          ABOUT SHANTI CLINIC
        </span>

        <h1>
          Compassionate Care,
          Modern Technology &
          Beautiful Results.
        </h1>

        <p>
          At Shanti Dental & Aesthetic Clinic,
          we combine advanced treatment,
          patient comfort and ethical healthcare
          to create confident smiles and healthier lives.
        </p>

        <div class="about-actions">

          <a
            href="/appointment"
            class="btn-big-dental"
          >
            Book Appointment
          </a>

          <a
            href="tel:+918732929431"
            class="btn-outline dental"
          >
            Call Now
          </a>

        </div>

      </div>

      <div class="about-image">

        <img
          src="/images/clinic-team.jpg"
          alt="Shanti Clinic"
        >

      </div>

    </div>

  </section>

  <!-- STORY -->

  <section class="about-story">

    <div class="container story-grid">

      <div>
        <img
          src="/images/clinic-interior.jpg"
          alt="Clinic"
        >
      </div>

      <div>

        <span class="section-mini">
          OUR STORY
        </span>

        <h2>
          Healthcare Designed Around People.
        </h2>

        <p>
          Shanti Dental & Aesthetic Clinic was
          established with a simple vision —
          provide modern, ethical and affordable
          healthcare under one roof.
        </p>

        <p>
          From routine dental care to advanced
          smile makeovers and aesthetic treatments,
          every treatment plan is personalized to
          the unique needs of each patient.
        </p>

      </div>

    </div>

  </section>

  <!-- WHY US -->

  <section class="why-section">

    <div class="container">

      <div class="section-head">

        <span class="kicker dental">
          WHY CHOOSE US
        </span>

        <h2 class="dental">
          Experience Healthcare Differently
        </h2>

      </div>

      <div class="why-grid">

        <div class="why-card">
          <h3>Advanced Technology</h3>
          <p>
            Digital diagnosis and modern equipment
            for precise treatments.
          </p>
        </div>

        <div class="why-card">
          <h3>Experienced Doctors</h3>
          <p>
            Skilled specialists focused on
            delivering excellent outcomes.
          </p>
        </div>

        <div class="why-card">
          <h3>Patient First</h3>
          <p>
            Transparent consultations and
            comfortable treatment experience.
          </p>
        </div>

        <div class="why-card">
          <h3>Complete Care</h3>
          <p>
            Dental and aesthetic solutions
            available under one roof.
          </p>
        </div>

      </div>

    </div>

  </section>

  <!-- STATS -->

  <section class="about-stats">

    <div class="container stats-grid">

      <div>
        <h3>2500+</h3>
        <p>Happy Patients</p>
      </div>

      <div>
        <h3>5000+</h3>
        <p>Treatments Completed</p>
      </div>

      <div>
        <h3>5★</h3>
        <p>Patient Rating</p>
      </div>

      <div>
        <h3>10+</h3>
        <p>Years Experience</p>
      </div>

    </div>

  </section>

  <!-- DOCTORS -->

  <section class="doctors-section">

    <div class="container">

      <div class="section-head">

        <span class="kicker dental">
          OUR DOCTORS
        </span>

        <h2 class="dental">
          Meet Our Specialists
        </h2>

      </div>

      <div class="doctor-grid">

        <div class="doctor-card">

          <img
            src="/images/dr-nikunj.jpg"
            alt="Dr Nikunj"
          >

          <h3>
            Dr. Nikunj Gupta
          </h3>

          <p>
            Oral & Maxillofacial Surgeon
          </p>

        </div>

        <div class="doctor-card">

          <img
            src="/images/dr-hinal.jpg"
            alt="Dr Hinal"
          >

          <h3>
            Dr. Hinal
          </h3>

          <p>
            Root Canal Specialist
          </p>

        </div>

      </div>

    </div>

  </section>

  <!-- MISSION -->

  <section class="mission-section">

    <div class="container mission-grid">

      <div class="mission-card">

        <h3>Our Mission</h3>

        <p>
          To provide ethical,
          affordable and advanced healthcare
          that improves confidence,
          well-being and quality of life.
        </p>

      </div>

      <div class="mission-card">

        <h3>Our Vision</h3>

        <p>
          To become Ahmedabad's most trusted
          destination for dental and
          aesthetic excellence.
        </p>

      </div>

    </div>

  </section>

  <!-- CTA -->

  <section class="about-cta">

    <div class="container">

      <h2>
        Ready To Transform Your Smile?
      </h2>

      <p>
        Schedule your consultation today.
      </p>

      <a
        href="/appointment"
        class="btn-big-dental"
      >
        Book Appointment
      </a>

    </div>

  </section>

</main>


