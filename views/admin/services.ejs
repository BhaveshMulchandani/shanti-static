<!DOCTYPE html>
<html>
<head>
    <title>All Services</title>
</head>
<body>

    <h1>All Services</h1>

    <a href="/admin/services/create">
        Create New Service
    </a>

    <hr>

    <% services.forEach(service => { %>

        <div
            style="
                border:1px solid #ccc;
                padding:15px;
                margin-bottom:15px;
            "
        >

            <h3>
                <%= service.title %>
            </h3>

            <p>
                <%= service.shortDescription %>
            </p>

            <p>
                Slug:
                <%= service.slug %>
            </p>

            <a
                href="/services/<%= service.slug %>"
                target="_blank"
            >
                View Live Page
            </a>

        </div>

    <% }) %>

</body>
</html>