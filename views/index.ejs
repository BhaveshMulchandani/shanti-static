<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Shanti Clinic — Dental & Aesthetic Care</title>
<meta name="description" content="Welcome to Shanti Clinic. Choose between Shanti Dental Clinic and Shanti Aesthetic Clinic for world-class care." />
<meta property="og:title" content="Shanti Clinic — Dental & Aesthetic Care" />
<meta property="og:description" content="Two clinics. One promise of excellence." />
<link rel="stylesheet" href="assets/css/style.css" />
</head>
<body>
  <div class="gateway">
    <header class="gateway-header">
      <div class="gateway-logo">SHANTI <span class="light">CLINIC</span></div>
    </header>
    <main class="gateway-main">
      <section class="gateway-panel panel-dental fade-in">
        <div class="overlay"></div>
        <div class="panel-inner fade-up">
          <div class="chip chip-light">🦷 Dental</div>
          <h1>Where Every Smile<br/>Feels Confident.</h1>
          <p>Smile makeovers, implants, orthodontics and modern preventative oral care — delivered with painless precision and digital diagnostics.</p>
          <a href="dental.html" class="btn btn-white-dental">
            Enter Dental Clinic
            <i data-lucide="arrow-right"></i>
          </a>
        </div>
      </section>
      <section class="gateway-panel panel-aesthetic fade-in">
        <div class="overlay"></div>
        <div class="panel-inner fade-up">
          <div class="chip chip-aesthetic"><i data-lucide="sparkles" style="width:.75rem;height:.75rem"></i> Aesthetic</div>
          <h1>Enhancing Beauty<br/>with Confidence.</h1>
          <p>Skin rejuvenation, anti-aging therapies, clinical hair restoration and contouring — refined by dermatological expertise.</p>
          <a href="aesthetic.html" class="btn btn-aesthetic">
            Enter Aesthetic Clinic
            <i data-lucide="arrow-right"></i>
          </a>
        </div>
      </section>
    </main>
    <div class="gateway-footer">© 2026 Shanti Clinic Group · One trusted name. Two specialised clinics.</div>
  </div>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script src="assets/js/main.js"></script>
